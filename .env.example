# ==========================================
# NYOTA Clinical Diagnostics Configuration
# ==========================================
# Copy this file to .env and update the paths for your environment

# ==========================================
# Server Configuration
# ==========================================
# Port on which the backend server runs
SERVER_PORT=3002

# Environment (development, staging, production)
NODE_ENV=development

# ==========================================
# ML Model Configuration
# ==========================================
# Path to the ML models directory
# Can be absolute path or relative to the server.js location
ML_MODELS_PATH=../models_senior_v4

# ML Model metadata file (relative to ML_MODELS_PATH)
ML_META_FILE=meta.json

# Feature importance CSV file (relative to ML_MODELS_PATH)
ML_FEATURE_IMPORTANCE_FILE=perm_importance_test.csv

# ==========================================
# Data Configuration
# ==========================================
# Path to the maternal health data CSV file
# Can be absolute path or relative to the server.js location
DATA_CSV_PATH=../nyota-api-local/maternal_data.csv

# ==========================================
# Frontend Configuration
# ==========================================
# API Base URL for frontend (where the backend server is)
# Default: http://localhost:3002
VITE_API_BASE_URL=http://localhost:3002

# Frontend Port (Vite development server)
# Default: 3003 (if 3000, 3001, 3002 are taken)
VITE_PORT=3003

# ==========================================
# Logging Configuration
# ==========================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable detailed logging
VERBOSE_LOGGING=false

# ==========================================
# Feature Flags
# ==========================================
# Enable ML model predictions
ENABLE_ML_PREDICTIONS=true

# Enable emergency alerts
ENABLE_EMERGENCY_ALERTS=true

# Enable clinical recommendations
ENABLE_CLINICAL_RECOMMENDATIONS=true
